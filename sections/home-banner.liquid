<style>
  .hero-wrapper {
    width: 100%;
  }

  .hero-wrapper.page-width {
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero-section {
    width: 100%;
    height: 717px;
    flex-shrink: 0;
    background-color: #f0efef;
    display: flex;
    align-items: stretch;
  }

  .hero-image-column {
    width: 50%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0px 40px;
    box-sizing: border-box;
  }

  .hero-image-column img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .hero-content-column {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
    box-sizing: border-box;
  }

  .hero-content-column.text-left {
    align-items: flex-start;
  }

  .hero-content-column.text-center {
    align-items: center;
  }

  .hero-content-column.text-right {
    align-items: flex-end;
  }

  .hero-heading {
    font-family: 'Archivo', sans-serif;
    font-weight: 500;
    font-size: 42px;
    color: #1e5649;
    margin-bottom: 30px;
    width: 100%;
  }

  .hero-content-column.text-left .hero-heading,
  .hero-content-column.text-left .hero-text {
    text-align: left;
  }

  .hero-content-column.text-center .hero-heading,
  .hero-content-column.text-center .hero-text {
    text-align: center;
  }

  .hero-content-column.text-right .hero-heading,
  .hero-content-column.text-right .hero-text {
    text-align: right;
  }

  .hero-text {
    font-family: 'Archivo', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #1e5649;
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 600px;
  }

  .hero-buttons {
    display: flex;
    gap: 15px;
    align-items: center;
  }

  .hero-content-column.text-left .hero-buttons {
    justify-content: flex-start;
  }

  .hero-content-column.text-center .hero-buttons {
    justify-content: center;
  }

  .hero-content-column.text-right .hero-buttons {
    justify-content: flex-end;
  }

  .hero-button {
    display: flex;
    padding: 19.368px 12.105px;
    justify-content: center;
    align-items: center;
    gap: 12.105px;
    border-radius: 10px;
    text-decoration: none;
    font-family: 'Archivo', sans-serif;
    font-weight: 500;
    font-size: 18px;
    transition: opacity 0.3s ease;
    border: none;
    cursor: pointer;
    height: 59px;
    min-width: 150px;
  }

  .hero-button-primary {
    background: #1F554A;
    color: #ffffff;
  }

  .hero-button-secondary {
    background: #BEDA8D;
    color: #1F554A;
  }

  .hero-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .hero-section {
      flex-direction: column;
      height: auto;
    }

    .hero-image-column,
    .hero-content-column {
      width: 100%;
    }

    .hero-image-column {
      height: 400px;
    }

    .hero-content-column {
      padding: 20px 20px;
    }

    .hero-heading {
      font-size: 30px;
      margin-bottom: 0;
      text-align: center !important;
    }

    .hero-content-column.text-left .hero-heading,
    .hero-content-column.text-right .hero-heading {
      text-align: center !important;
    }

    .hero-text {
      font-size: 14px;
      text-align: center !important;
    }

    .hero-content-column.text-left .hero-text,
    .hero-content-column.text-right .hero-text {
      text-align: center !important;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
    }

    .hero-button {
      width: 100%;
      max-width: 349px;
    }
  }
</style>

<div class="hero-wrapper {% if section.settings.width == 'page_width' %}page-width{% endif %}">
  <section class="hero-section">
    <div class="hero-content-column text-{{ section.settings.text_alignment | default: 'center' }}">
      <h1 class="hero-heading">{{ section.settings.heading }}</h1>
      <p class="hero-text">{{ section.settings.text }}</p>
      <div class="hero-buttons">
        {% liquid
          assign button1_is_js = false
          assign button2_is_js = false
          
          if section.settings.button_link contains 'openQuoteModal' or section.settings.button_link contains 'javascript:'
            assign button1_is_js = true
          endif
          
          if section.settings.button2_link contains 'openQuoteModal' or section.settings.button2_link contains 'javascript:'
            assign button2_is_js = true
          endif
        %}
        
        {% if button1_is_js %}
          <button
            type="button"
            class="hero-button hero-button-primary"
            onclick="{% if section.settings.button_link contains 'openQuoteModal' %}window.openQuoteModal();{% else %}{{ section.settings.button_link | remove_first: 'javascript:' }}{% endif %}"
          >
            {{ section.settings.button_text }}
          </button>
        {% else %}
          <a href="{{ section.settings.button_link }}" class="hero-button hero-button-primary">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
        
        {% if button2_is_js %}
          <button
            type="button"
            class="hero-button hero-button-secondary"
            onclick="{% if section.settings.button2_link contains 'openQuoteModal' %}window.openQuoteModal();{% else %}{{ section.settings.button2_link | remove_first: 'javascript:' }}{% endif %}"
          >
            {{ section.settings.button2_text }}
          </button>
        {% else %}
          <a href="{{ section.settings.button2_link }}" class="hero-button hero-button-secondary">
            {{ section.settings.button2_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="hero-image-column">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | img_url: 'master' }}" alt="{{ section.settings.heading }}">
      {% else %}
        <img src="https://via.placeholder.com/960x717/cccccc/666666?text=Add+Hero+Image" alt="Placeholder">
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "Section Width",
      "options": [
        {
          "value": "full_width",
          "label": "Full Width"
        },
        {
          "value": "page_width",
          "label": "Page Width"
        }
      ],
      "default": "full_width"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Italian soul in the heart of Sydney."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "At the corner of Phillip and Bent Street, Eatalo is where the warmth of an Italian café meets the buzz of the Sydney CBD. From your morning coffee wraps to fresh panini, homemade pasta and seasonal creations, our menu blends the best of Italy's culinary traditions with the quality of Australian produce. Whether you're here for a quick takeaway, a long lunch, or simply a good coffee before work, Eatalo is your local slice of Italy... Buon Appetito!"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Reserve a Table"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button2_text",
      "label": "Second Button Text",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Second Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}