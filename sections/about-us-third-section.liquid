{% style %}
  .chef-section {
    width: 100%;
    background-color: #e5e0da;
    display: flex;
  }

  .chef-section__image {
    width: 50%;
    background-color: #1e5649;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .chef-section__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .chef-section__content {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 100px;
  }

  .chef-section__heading {
    font-family: 'Archivo Medium', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    color: #1e5649;
    text-align: right;
    margin-bottom: 30px;
  }

  .chef-section__text {
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    color: #1e5649;
    text-align: right;
  }

  @media screen and (max-width: 768px) {
    .chef-section {
      flex-direction: column;
      height: auto;
    }

    .chef-section__image,
    .chef-section__content {
      width: 100%;
    }

    .chef-section__image {
      height: 400px;
    }

    .chef-section__content {
      padding: 40px 20px;
    }

    .chef-section__heading {
      font-size: 28px;
      text-align: center;
    }

    .chef-section__text {
      text-align: center;
    }
  }
{% endstyle %}

<div class="chef-section">
  <div class="chef-section__image">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
    {% else %}
      <div style="color: #a8b5a0; font-family: 'Archivo', sans-serif; font-size: 80px; font-weight: 600; text-align: center;">
        Chef<br>Image
      </div>
    {% endif %}
  </div>
  
  <div class="chef-section__content">
    <h2 class="chef-section__heading">{{ section.settings.heading }}</h2>
    <div class="chef-section__text">{{ section.settings.description }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Chef Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Chef Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Chef"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>At EATALO, coffee isn't just part of the menu, it's part of who we are. We've created our very own EATALO Blend, a smooth, full-bodied coffee roasted to capture the heart of Italy in every sip. Whether it's your morning espresso, a creamy cappuccino, or a quick long black on the go, we're here to greet you with a smile and a loud \"Buongiorno!\" From takeaway to dine-in, our coffee pairs perfectly with breakfast, lunch, or those in-between moments when you just need something delicious. At EATALO, every cup is made to make your day brighter, one coffee, one smile at a time.</p>"
    }
  ],
  "presets": [
    {
      "name": "Chef Section"
    }
  ]
}
{% endschema %}