<style>
  .contact-section {
    width: 100%;
    height: 300px;
    flex-shrink: 0;
    background-color: #f8f2ec;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 20px;
  }

  .contact-section__title {
    font-family: "Archivo", sans-serif;
    font-size: 30px;
    font-weight: 400;
    color: #1e5649;
    margin: 0 0 20px 0;
  }

  .contact-section__text {
    font-family: "Archivo", sans-serif;
    font-size: 18px;
    color: #1e5649;
    margin: 0 0 30px 0;
    line-height: 1.6;
  }

  .contact-section__text p {
    margin: 0;
  }

  .contact-section__text p + p {
    margin-top: {{ section.settings.line_spacing }}px;
  }

  .contact-section__icon {
    width: 28px;
    height: 28px;
    display: inline-block;
    color: #000000;
  }

  .contact-section__icon svg {
    width: 100%;
    height: 100%;
  }
</style>

<section class="contact-section">
  <h2 class="contact-section__title">{{ section.settings.heading }}</h2>
  
  <div class="contact-section__text">
    <p>{{ section.settings.text_line_1 }}</p>
    <p>{{ section.settings.text_line_2 }}</p>
  </div>

  {% if section.settings.instagram_url != blank %}
    <a href="{{ section.settings.instagram_url }}" class="contact-section__icon" target="_blank" rel="noopener" aria-label="Follow us on Instagram">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="#000000"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="none" stroke="#000000"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="#000000" stroke-width="2"></line>
      </svg>
    </a>
  {% endif %}
</section>

{% schema %}
{
  "name": "Contact Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact us"
    },
    {
      "type": "textarea",
      "id": "text_line_1",
      "label": "Text Line 1",
      "default": "Have an enquiry? Send us your feedback."
    },
    {
      "type": "textarea",
      "id": "text_line_2",
      "label": "Text Line 2",
      "default": "We'd love to hear from you!"
    },
    {
      "type": "range",
      "id": "line_spacing",
      "label": "Gap between text lines (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    }
  ],
  "presets": [
    {
      "name": "Contact Us"
    }
  ]
}
{% endschema %}