{% assign section_id = 'why-clients-' | append: section.id %}

<section id="{{ section_id }}">
  <div class="wc-inner">
    <h2 class="wc-heading">{{ section.settings.heading }}</h2>
    <div class="wc-grid">
      {% for block in section.blocks %}
        <div class="wc-item" {{ block.shopify_attributes }}>
          <span class="wc-check">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="2.5" fill="none"/>
              <path d="M10 18.5 L15.5 24 L26 13" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="wc-text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  #{{ section_id }} .wc-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #{{ section_id }} .wc-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    line-height: 1.2;
  }

  #{{ section_id }} .wc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    row-gap: {{ section.settings.row_gap }}px;
    column-gap: {{ section.settings.column_gap }}px;
  }

  #{{ section_id }} .wc-item {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  #{{ section_id }} .wc-check {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #{{ section_id }} .wc-check svg {
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .wc-text {
    font-size: {{ section.settings.item_size }}px;
    font-weight: 400;
    color: {{ section.settings.item_color }};
    line-height: 1.4;
  }

  @media screen and (max-width: 680px) {
    #{{ section_id }} {
      padding-left: 24px;
      padding-right: 24px;
    }

    #{{ section_id }} .wc-heading {
      font-size: {{ section.settings.heading_size | minus: 10 }}px;
    }

    #{{ section_id }} .wc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Why Clients Love This",
  "tag": "section",
  "class": "why-clients-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Clients Love This Option"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 46
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a4d38"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading Margin Bottom",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#d9e8c4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Row Gap",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Checkmark Color",
      "default": "#1a4d38"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Checkmark Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "font_picker",
      "id": "item_font",
      "label": "Item Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "item_size",
      "label": "Item Font Size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "item_color",
      "label": "Item Text Color",
      "default": "#1a4d38"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Checklist Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Add your benefit here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Clients Love This",
      "blocks": [
        { "type": "item", "settings": { "text": "Feels premium without the venue price" } },
        { "type": "item", "settings": { "text": "Creates a \"wow\" factor" } },
        { "type": "item", "settings": { "text": "Restaurant quality service, anywhere" } },
        { "type": "item", "settings": { "text": "Completely customisable" } },
        { "type": "item", "settings": { "text": "Zero stress for hosts" } },
        { "type": "item", "settings": { "text": "Memorable for all the right reasons" } }
      ]
    }
  ]
}
{% endschema %}