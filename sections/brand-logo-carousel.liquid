{% comment %}
  Brand Logo Carousel Section
  Displays brand logos in a horizontally scrolling carousel
{% endcomment %}

{% liquid
  assign section_settings = section.settings
  assign logo_count = section.blocks.size
%}

<style>
  .brand-logo-carousel-section {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    padding: {{ section_settings.padding_top }}px 0 {{ section_settings.padding_bottom }}px;
    background-color: {{ section_settings.background_color }};
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }

  .brand-logo-carousel-section::before,
  .brand-logo-carousel-section::after {
    content: '';
    position: absolute;
    top: 0;
    width: 60px;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .brand-logo-carousel-section::before {
    left: 0;
    background: linear-gradient(to right, {{ section_settings.background_color }}, transparent);
  }

  .brand-logo-carousel-section::after {
    right: 0;
    background: linear-gradient(to left, {{ section_settings.background_color }}, transparent);
  }

  .brand-logo-carousel-inner {
    max-width: 100%;
    padding: 0 {{ section_settings.padding_sides }}px;
  }

  .brand-logo-carousel-heading {
    text-align: {{ section_settings.heading_alignment }};
    margin: 0 0 {{ section_settings.heading_spacing }}px 0;
    font-family: 'Archivo', sans-serif;
    font-size: 42px;
    font-weight: {{ section_settings.heading_weight }};
    color: {{ section_settings.heading_color }};
  }

  .brand-logo-carousel-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .brand-logo-carousel-track {
    display: flex;
    gap: {{ section_settings.logo_gap }}px;
    width: fit-content;
    animation: scroll-{{ section.id | replace: '-', '' }} {{ section_settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .brand-logo-carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-{{ section.id | replace: '-', '' }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - {{ section_settings.logo_gap | divided_by: 2 }}px));
    }
  }

  .brand-logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section_settings.logo_width }}px;
    height: {{ section_settings.logo_height }}px;
    padding: {{ section_settings.logo_padding }}px;
    background-color: {{ section_settings.logo_background }};
    border-radius: {{ section_settings.logo_border_radius }}px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .brand-logo-item:hover {
    transform: scale({{ section_settings.logo_hover_scale }});
    opacity: 0.9;
  }

  .brand-logo-item img,
  .brand-logo-item .brand-logo-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: {{ section_settings.logo_filter }};
    transition: filter 0.3s ease;
  }

  .brand-logo-item a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  /* Mobile styles */
  @media screen and (max-width: 750px) {
    .brand-logo-carousel-section {
      padding: {{ section_settings.padding_top_mobile }}px 0 {{ section_settings.padding_bottom_mobile }}px;
    }

    .brand-logo-carousel-section::before,
    .brand-logo-carousel-section::after {
      width: 30px;
    }

    .brand-logo-carousel-inner {
      padding: 0 {{ section_settings.padding_sides_mobile }}px;
    }

    .brand-logo-carousel-heading {
      font-size: {{ section_settings.heading_size_mobile }}px;
      margin-bottom: {{ section_settings.heading_spacing_mobile }}px;
    }

    .brand-logo-item {
      width: {{ section_settings.logo_width_mobile }}px;
      height: {{ section_settings.logo_height_mobile }}px;
      padding: {{ section_settings.logo_padding_mobile }}px;
    }

    .brand-logo-carousel-track {
      gap: {{ section_settings.logo_gap_mobile }}px;
    }
  }
</style>

<section class="brand-logo-carousel-section" {{ section.shopify_attributes }}>
  <div class="brand-logo-carousel-inner">
    {% if section_settings.heading != blank %}
      <h2 class="brand-logo-carousel-heading">{{ section_settings.heading }}</h2>
    {% endif %}

    <div class="brand-logo-carousel-wrapper">
    <div class="brand-logo-carousel-track" id="brand-carousel-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="brand-logo-item" {{ block.shopify_attributes }}>
          {% if block.settings.logo_link != blank %}
            <a href="{{ block.settings.logo_link }}" {% if block.settings.logo_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
              {% if block.settings.logo != blank %}
                {% assign logo_alt = block.settings.logo.alt | default: block.settings.brand_name | default: 'Brand logo' %}
                {% assign logo_width_2x = section_settings.logo_width | times: 2 %}
                <img
                  src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
                  alt="{{ logo_alt }}"
                  width="{{ section_settings.logo_width }}"
                  height="{{ section_settings.logo_height }}"
                  loading="lazy"
                  class="brand-logo-image"
                >
              {% else %}
                <span>{{ block.settings.brand_name | default: 'Brand' }}</span>
              {% endif %}
            </a>
          {% else %}
            {% if block.settings.logo != blank %}
              {% assign logo_alt = block.settings.logo.alt | default: block.settings.brand_name | default: 'Brand logo' %}
              {% assign logo_width_2x = section_settings.logo_width | times: 2 %}
              <img
                src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
                alt="{{ logo_alt }}"
                width="{{ section_settings.logo_width }}"
                height="{{ section_settings.logo_height }}"
                loading="lazy"
                class="brand-logo-image"
              >
            {% else %}
              <span>{{ block.settings.brand_name | default: 'Brand' }}</span>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
      
      {% comment %} Duplicate logos for seamless infinite scroll {% endcomment %}
      {% for block in section.blocks %}
        <div class="brand-logo-item">
          {% if block.settings.logo_link != blank %}
            <a href="{{ block.settings.logo_link }}" {% if block.settings.logo_link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
              {% if block.settings.logo != blank %}
                {% assign logo_alt = block.settings.logo.alt | default: block.settings.brand_name | default: 'Brand logo' %}
                {% assign logo_width_2x = section_settings.logo_width | times: 2 %}
                <img
                  src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
                  alt="{{ logo_alt }}"
                  width="{{ section_settings.logo_width }}"
                  height="{{ section_settings.logo_height }}"
                  loading="lazy"
                  class="brand-logo-image"
                >
              {% else %}
                <span>{{ block.settings.brand_name | default: 'Brand' }}</span>
              {% endif %}
            </a>
          {% else %}
            {% if block.settings.logo != blank %}
              {% assign logo_alt = block.settings.logo.alt | default: block.settings.brand_name | default: 'Brand logo' %}
              {% assign logo_width_2x = section_settings.logo_width | times: 2 %}
              <img
                src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
                alt="{{ logo_alt }}"
                width="{{ section_settings.logo_width }}"
                height="{{ section_settings.logo_height }}"
                loading="lazy"
                class="brand-logo-image"
              >
            {% else %}
              <span>{{ block.settings.brand_name | default: 'Brand' }}</span>
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Logo Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Partners"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size (Desktop)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading Size (Mobile)",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Heading Weight",
      "min": 300,
      "max": 700,
      "step": 100,
      "default": 500
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2d5f5d"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading Bottom Spacing (Desktop)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_spacing_mobile",
      "label": "Heading Bottom Spacing (Mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll Speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Time for one complete cycle (lower = faster)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width (Desktop)",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Height (Desktop)",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo Width (Mobile)",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo Height (Mobile)",
      "min": 40,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Logo Gap (Desktop)",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_gap_mobile",
      "label": "Logo Gap (Mobile)",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "logo_padding",
      "label": "Logo Padding (Desktop)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_padding_mobile",
      "label": "Logo Padding (Mobile)",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "logo_background",
      "label": "Logo Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "logo_border_radius",
      "label": "Logo Border Radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "logo_hover_scale",
      "label": "Logo Hover Scale",
      "min": 1,
      "max": 1.3,
      "step": 0.1,
      "default": 1.1,
      "info": "Scale factor when hovering over logos"
    },
    {
      "type": "select",
      "id": "logo_filter",
      "label": "Logo Filter",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "grayscale(100%)",
          "label": "Grayscale"
        },
        {
          "value": "grayscale(100%) opacity(0.7)",
          "label": "Grayscale + Fade"
        },
        {
          "value": "brightness(0.8)",
          "label": "Darker"
        },
        {
          "value": "brightness(1.2)",
          "label": "Brighter"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_sides",
      "label": "Padding Sides (Desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_sides_mobile",
      "label": "Padding Sides (Mobile)",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "info": "Used as alt text if logo image is not provided"
        },
        {
          "type": "url",
          "id": "logo_link",
          "label": "Logo Link",
          "info": "Optional: Link the logo to a URL"
        },
        {
          "type": "checkbox",
          "id": "logo_link_new_tab",
          "label": "Open Link in New Tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logo Carousel",
      "blocks": [
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        },
        {
          "type": "brand_logo"
        }
      ]
    }
  ]
}
{% endschema %}

