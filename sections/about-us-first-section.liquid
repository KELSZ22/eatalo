{% style %}
  .buongiorno-section {
    width: 100%;
    background-color: #e5e0da;
    display: flex;
  }

  .buongiorno-image {
    width: 50%;
    background-color: #1e5649;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
    padding: 40px;
  }

  .buongiorno-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .buongiorno-placeholder {
    color: #a8b5a0;
    font-family: 'Archivo', sans-serif;
    font-size: 80px;
    font-weight: 600;
    line-height: 1;
    padding: 20px;
  }

  .buongiorno-content {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 100px;
  }

  .buongiorno-heading {
    font-family: 'Archivo Medium', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    color: #1e5649;
    text-align: right;
    margin-bottom: 30px;
  }

  .buongiorno-text {
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    color: #1e5649;
    text-align: right;
  }

  @media screen and (max-width: 768px) {
    .buongiorno-section {
      flex-direction: column;
      height: auto;
    }

    .buongiorno-image,
    .buongiorno-content {
      width: 100%;
    }

    .buongiorno-image {
      min-height: 300px;
      height: auto;
      padding: 40px 20px;
    }

    .buongiorno-placeholder {
      font-size: 60px;
    }

    .buongiorno-content {
      padding: 40px 20px;
    }

    .buongiorno-heading {
      font-size: 28px;
      text-align: center;
    }

    .buongiorno-text {
      text-align: center;
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="buongiorno-section">
  <div class="buongiorno-image">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
    {% else %}
      <div class="buongiorno-placeholder">
        Buon<br>giorno
      </div>
    {% endif %}
  </div>
  
  <div class="buongiorno-content">
    <h2 class="buongiorno-heading">{{ section.settings.heading }}</h2>
    <div class="buongiorno-text">{{ section.settings.description }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Buongiorno Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Buongiorno"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>At EATALO, coffee isn't just part of the menu, it's part of who we are. We've created our very own EATALO Blend, a smooth, full-bodied coffee roasted to capture the heart of Italy in every sip. Whether it's your morning espresso, a creamy cappuccino, or a quick long black on the go, we're here to greet you with a smile and a loud \"Buongiorno!\" From takeaway to dine-in, our coffee pairs perfectly with breakfast, lunch, or those in-between moments when you just need something delicious. At EATALO, every cup is made to make your day brighter, one coffee, one smile at a time.</p>"
    }
  ],
  "presets": [
    {
      "name": "Buongiorno Section"
    }
  ]
}
{% endschema %}