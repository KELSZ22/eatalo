{% style %}
  .catering-section {
    width: 100%;
    display: flex;
  }

  .catering-section__content {
    width: 50%;
    background-color: #dfe7c1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 100px;
  }

  .catering-section__heading {
    font-family: 'Archivo Medium', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    color: #1e5649;
    text-align: left;
    margin-bottom: 30px;
  }

  .catering-section__text {
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    color: #1e5649;
    text-align: left;
  }

  .catering-section__image {
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .catering-section__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .catering-section {
      flex-direction: column;
      height: auto;
    }

    .catering-section__content,
    .catering-section__image {
      width: 100%;
    }

    .catering-section__image {
      height: 400px;
      order: -1;
    }

    .catering-section__content {
      padding: 40px 20px;
    }

    .catering-section__heading {
      font-size: 28px;
      text-align: center;
    }

    .catering-section__text {
      text-align: center;
    }
  }
{% endstyle %}

<div class="catering-section">
  <div class="catering-section__content">
    <h2 class="catering-section__heading">{{ section.settings.heading }}</h2>
    <div class="catering-section__text">{{ section.settings.description }}</div>
  </div>

  <div class="catering-section__image">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
    {% else %}
      <div style="color: #1e5649; font-family: 'Archivo', sans-serif; font-size: 80px; font-weight: 600; text-align: center; background-color: #f5f5f5; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
        Image
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Catering Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Catering Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EATALO Kitchen Catering"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We pride ourselves on delivering fresh, vibrant, and creative catering that makes every occasion memorable. From signature breakfast platters and wholesome salads to handmade pastas, protein spreads, and elegant canapés, our menu is designed to suit any event: office meetings, corporate celebrations, educational gatherings, or milestone moments.</p>"
    }
  ],
  "presets": [
    {
      "name": "Catering Section"
    }
  ]
}
{% endschema %}