{% assign section_id = 'perfect-for-' | append: section.id %}

<section id="{{ section_id }}">
  <div class="pf-inner">
    <h2 class="pf-heading">{{ section.settings.heading }}</h2>
    <div class="pf-grid">
      {% for block in section.blocks %}
        <div class="pf-item" {{ block.shopify_attributes }}>
          <div class="pf-image-wrap">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'pf-image', alt: block.settings.label, loading: 'lazy' }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'pf-placeholder' }}
            {% endif %}
          </div>
          <div class="pf-label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  #{{ section_id }} .pf-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #{{ section_id }} .pf-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    line-height: 1.2;
  }

  #{{ section_id }} .pf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  #{{ section_id }} .pf-item {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #{{ section_id }} .pf-image-wrap {
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  #{{ section_id }} .pf-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .pf-placeholder {
    width: 100%;
    height: 100%;
    background: #e0ddd8;
  }

  #{{ section_id }} .pf-label {
    font-size: {{ section.settings.label_size }}px;
    font-weight: 400;
    color: {{ section.settings.label_color }};
    line-height: 1.3;
  }

  @media screen and (max-width: 640px) {
    #{{ section_id }} {
      padding-left: 20px;
      padding-right: 20px;
    }

    #{{ section_id }} .pf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Perfect For",
  "tag": "section",
  "class": "perfect-for-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Perfect For..."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a5c3a"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading Margin Bottom",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" },
        { "value": "1/1", "label": "1:1 Square" }
      ],
      "default": "3/2"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "font_picker",
      "id": "label_font",
      "label": "Label Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label Font Size",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#1a5c3a"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Event Type"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfect For",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "label": "Corporate Dinners & Client Entertaining"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Private Parties & Milestone Celebrations"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Product Launches & Brand Events"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Intimate Weddings & Engagement Parties"
          }
        }
      ]
    }
  ]
}
{% endschema %}