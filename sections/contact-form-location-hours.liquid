<style>
  .contact-form-wrapper {
    background-color: #f8f2ec;
    width: 100%;
    height: 900px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .contact-form-inner {
    display: flex;
    max-width: 1400px;
    width: 100%;
    height: 100%;
    gap: 60px;
  }

  .contact-form-left {
    flex: 0 0 40%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: 0;
  }

  .contact-form-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .form-field {
    width: 100%;
    padding: 20px 20px;
    border: 1px solid #d4c4b4;
    background-color: transparent;
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #2c5f4f;
    border-radius: 0;
  }

  .form-field::placeholder {
    color: #a8a8a8;
    font-weight: 400;
  }

  .form-field:focus {
    outline: none;
    border-color: #2c5f4f;
  }

  .form-textarea {
    min-height: 350px;
    resize: vertical;
    font-family: 'Archivo', sans-serif;
  }

  .form-submit-btn {
    width: 100%;
    padding: 15px;
    background-color: #1e5649;
    color: white;
    border: none;
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .form-submit-btn:hover {
    background-color: #153f35;
  }

  .location-map-container {
    width: 100%;
    height: 400px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .location-map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .location-info-row {
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  .contact-info-block,
  .hours-info-block {
    flex: 1;
  }

  .info-heading {
    color: #2c5f4f;
    font-family: 'Archivo', sans-serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .info-text {
    color: #2c5f4f;
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.6;
    margin: 5px 0;
  }

  .info-address {
    margin-top: 15px;
  }

  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hours-list li {
    color: #2c5f4f;
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  @media (max-width: 1024px) {
    .contact-form-wrapper {
      height: auto;
      padding: 40px 20px;
    }

    .contact-form-inner {
      flex-direction: column;
      gap: 40px;
    }

    .contact-form-left {
      flex: 1;
    }

    .location-info-row {
      flex-direction: column;
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .location-map-container {
      height: 300px;
    }

    .info-heading {
      font-size: 18px;
    }

    .info-text,
    .hours-list li {
      font-size: 14px;
    }
  }
</style>

<div class="contact-form-wrapper">
  <div class="contact-form-inner">
    <div class="contact-form-left">
      {%- form 'contact', id: 'contact_form', class: 'contact-form' -%}
        {%- assign contact_success = false -%}
        {%- if form.posted_successfully? or request.params.contact_posted -%}
          {%- assign contact_success = true -%}
        {%- endif -%}

        {%- if form.errors -%}
          <p class="info-text" style="margin: 0 0 20px; font-weight: 600;" tabindex="-1" autofocus>
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </p>
        {%- endif -%}

        <div
          class="contact-success-modal"
          data-contact-success-modal
          {% unless contact_success %}hidden{% endunless %}
          aria-hidden="{% if contact_success %}false{% else %}true{% endif %}"
        >
          <div class="contact-success-modal__overlay" data-contact-success-close></div>
          <div
            class="contact-success-modal__dialog"
            role="dialog"
            aria-modal="true"
            aria-label="Thank you for your enquiry, we will get in touch with you very shortly."
          >
            <button type="button" class="contact-success-modal__close" data-contact-success-close aria-label="Close">
              ×
            </button>
            <p class="contact-success-modal__title">
              Thank you for your enquiry, we will get in touch with you very shortly.
            </p>
          </div>
        </div>

        <input
          type="text"
          name="contact[name]"
          class="form-field"
          placeholder="Name"
          required
          value="{{ form.name | escape }}"
        >

        <input
          type="text"
          name="contact[company]"
          class="form-field"
          placeholder="Company Name"
          style="margin-top: 20px;"
        >

        <input
          type="tel"
          name="contact[phone]"
          class="form-field"
          placeholder="Phone"
          style="margin-top: 20px;"
          value="{{ form.phone | escape }}"
        >

        <input
          type="email"
          name="contact[email]"
          class="form-field"
          placeholder="e-mail"
          required
          style="margin-top: 20px;"
          value="{{ form.email | escape }}"
          {% if form.errors contains 'email' %}
            aria-invalid="true"
          {% endif %}
        >

        <textarea
          name="contact[body]"
          class="form-field form-textarea"
          placeholder="Message"
          style="margin-top: 20px;"
        >{{- form.body | escape -}}</textarea>

        <button type="submit" class="form-submit-btn" style="margin-top: 20px;">SUBMIT</button>
      {%- endform -%}
    </div>

    <div class="contact-form-right">
      <div class="location-map-container">
        <iframe
          src="{{ section.settings.map_embed_url }}"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>

      <div class="location-info-row">
        <div class="contact-info-block">
          <h3 class="info-heading">CONTACT</h3>
          <p class="info-text">{{ section.settings.phone }}</p>
          <p class="info-text" style="font-weight: 600;">{{ section.settings.email }}</p>
          <div class="info-address">
            <p class="info-text">{{ section.settings.address_line1 }}</p>
            <p class="info-text">{{ section.settings.address_line2 }}</p>
          </div>
        </div>

        <div class="hours-info-block">
          <h3 class="info-heading">OPEN HOURS</h3>
          <ul class="hours-list">
            <li><strong>MON:</strong> 5:30am - 15:00pm</li>
            <li><strong>TUES:</strong> 5:30am - 15:00pm</li>
            <li><strong>WED:</strong> 5:30am - 15:00pm</li>
            <li><strong>THURS:</strong> 5:30am - 15:00pm</li>
            <li><strong>FRI:</strong> 5:30am - 15:00pm</li>
            <li><strong>SAT:</strong> CLOSED</li>
            <li><strong>SUN:</strong> CLOSED</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .contact-success-modal[hidden] {
    display: none !important;
  }

  .contact-success-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    padding: 24px;
    font-family: 'Archivo', sans-serif;
  }

  .contact-success-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
  }

  .contact-success-modal__dialog {
    position: relative;
    width: min(520px, 100%);
    background: #fff;
    color: #1e5649;
    border: 1px solid rgba(30, 86, 73, 0.18);
    border-radius: 14px;
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.32),
      0 2px 8px rgba(0, 0, 0, 0.12);
    padding: 22px 20px;
    text-align: center;
    transform: translateY(6px) scale(0.99);
    opacity: 0;
    animation: contactSuccessIn 180ms ease-out forwards;
  }

  @keyframes contactSuccessIn {
    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  .contact-success-modal__close {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 36px;
    height: 36px;
    border: 0;
    background: transparent;
    cursor: pointer;
    font-size: 28px;
    line-height: 36px;
    color: #1e5649;
    border-radius: 10px;
  }

  .contact-success-modal__close:hover {
    background: rgba(30, 86, 73, 0.08);
  }

  .contact-success-modal__close:focus-visible {
    outline: 2px solid rgba(30, 86, 73, 0.55);
    outline-offset: 2px;
  }

  .contact-success-modal__title {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.2px;
    line-height: 1.45;
    color: #1e5649;
  }
</style>

<script>
  (() => {
    const modal = document.querySelector('[data-contact-success-modal]');
    if (!modal || modal.hasAttribute('hidden')) return;

    const stripContactPostedParam = () => {
      try {
        const url = new URL(window.location.href);
        const hadQueryParam = url.searchParams.has('contact_posted');
        if (hadQueryParam) url.searchParams.delete('contact_posted');

        let hash = url.hash || '';
        const hadHashParam = hash.toLowerCase().includes('contact_posted');
        if (hadHashParam) hash = '';

        if (!hadQueryParam && !hadHashParam) return;
        const newUrl = `${url.pathname}${url.search}${hash}`;
        window.history.replaceState({}, '', newUrl);
      } catch (e) {
        // no-op
      }
    };

    const close = () => {
      modal.setAttribute('hidden', '');
      modal.setAttribute('aria-hidden', 'true');
      stripContactPostedParam();
    };

    modal.querySelectorAll('[data-contact-success-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    const closeBtn = modal.querySelector('.contact-success-modal__close');
    if (closeBtn) closeBtn.focus();

    stripContactPostedParam();
  })();
</script>

{% schema %}
{
  "name": "Contact Form Section",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "02 9241 2127"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@eatalo.com.au"
    },
    {
      "type": "text",
      "id": "address_line1",
      "label": "Address Line 1",
      "default": "Eatalo Cafe, Shop 2,"
    },
    {
      "type": "text",
      "id": "address_line2",
      "label": "Address Line 2",
      "default": "8-18 Bent Street, Sydney"
    },
    {
      "type": "url",
      "id": "map_embed_url",
      "label": "Google Maps Embed URL"
    }
  ],
  "presets": [
    {
      "name": "Contact Form Section"
    }
  ]
}
{% endschema %}
