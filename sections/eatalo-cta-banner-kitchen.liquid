<style>
  .cta-banner {
    width: 100%;
    height: 280px;
    flex-shrink: 0;
    background-color: #dfe7c1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 20px 10px;
  }

  .cta-banner__heading {
    color: #1e5649;
    text-align: center;
    font-family: 'Archivo', sans-serif;
    font-size: 42px;
    font-style: normal;
    font-weight: 500;
    line-height: 123%;
    margin-bottom: 24px;
    margin-top: 0;
  }

  .cta-banner__text {
    font-family: 'Archivo', sans-serif;
    font-weight: 400;
    font-size: 16px;
    color: #1e5649;
    text-align: center;
    max-width: 900px;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .cta-banner__heading {
      font-size: 32px;
    }

    .cta-banner__text {
      font-size: 14px;
    }
  }
</style>

<div class="cta-banner">
  <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
  <p class="cta-banner__text">{{ section.settings.text }}</p>
</div>

{% schema %}
{
  "name": "Eatalo CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Eatalo Kitchen Catering"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description Text",
      "default": "EATALO Kitchen Project brings authentic Italian catering to the Sydney CBD – wholesome, flavourful dishes made with quality produce, perfect for corporate events, meetings, and celebrations."
    }
  ],
  "presets": [
    {
      "name": "Eatalo CTA Banner"
    }
  ]
}
{% endschema %}
