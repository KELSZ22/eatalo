{% assign section_id = 'service-section-' | append: section.id %}

<section id="{{ section_id }}" class="service-section">
  <div class="service-inner">
    <h2 class="service-heading">{{ section.settings.heading }}</h2>
    <div class="service-grid">
      {% for block in section.blocks %}
        <div class="service-item" {{ block.shopify_attributes }}>
          <div class="service-icon">
            {% if block.settings.icon == 'building' %}
              <svg viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="10" y="6" width="34" height="42" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
                <rect x="16" y="2" width="22" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="16" y1="20" x2="38" y2="20" stroke="currentColor" stroke-width="1.5"/>
                <line x1="16" y1="28" x2="38" y2="28" stroke="currentColor" stroke-width="1.5"/>
                <line x1="16" y1="36" x2="30" y2="36" stroke="currentColor" stroke-width="1.5"/>
                <rect x="6" y="14" width="6" height="28" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <rect x="42" y="14" width="6" height="28" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            {% elsif block.settings.icon == 'plate' %}
              <svg viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="27" cy="27" r="18" stroke="currentColor" stroke-width="2" fill="none"/>
                <circle cx="27" cy="27" r="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M20 14 L18 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M34 14 L36 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="18" y1="8" x2="36" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M21 38 L20 46 M33 38 L34 46" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="18" y1="46" x2="36" y2="46" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            {% elsif block.settings.icon == 'cloche' %}
              <svg viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 30 Q27 16 44 30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
                <ellipse cx="27" cy="30" rx="17" ry="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M32 26 L38 20 L44 22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="24" y="33" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="18" y1="37" x2="36" y2="37" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            {% elsif block.settings.icon == 'dining' %}
              <svg viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="20" width="38" height="26" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
                <line x1="8" y1="28" x2="46" y2="28" stroke="currentColor" stroke-width="1.5"/>
                <line x1="27" y1="28" x2="27" y2="46" stroke="currentColor" stroke-width="1.5"/>
                <path d="M16 20 L16 14 M38 20 L38 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="16" cy="12" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="38" cy="12" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="20" y1="34" x2="24" y2="34" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="30" y1="34" x2="34" y2="34" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="20" y1="38" x2="24" y2="38" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="30" y1="38" x2="34" y2="38" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="20" y1="42" x2="24" y2="42" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="30" y1="42" x2="34" y2="42" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            {% elsif block.settings.custom_icon != blank %}
              {{ block.settings.custom_icon | image_url: width: original | image_tag: class: 'custom-icon-img', alt: block.settings.title }}
            {% endif %}
          </div>
          <div class="service-title">{{ block.settings.title }}</div>
          <div class="service-desc">{{ block.settings.description }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  }

  #{{ section_id }} .service-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #{{ section_id }} .service-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_font.weight | default: 400 }};
    color: {{ section.settings.heading_color }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    line-height: 1.2;
  }

  #{{ section_id }} .service-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.column_gap }}px;
  }

  #{{ section_id }} .service-item {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  #{{ section_id }} .service-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
    margin-bottom: 4px;
  }

  #{{ section_id }} .service-icon svg {
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .custom-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #{{ section_id }} .service-title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    line-height: 1.3;
  }

  #{{ section_id }} .service-desc {
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    #{{ section_id }} {
      padding-left: 24px;
      padding-right: 24px;
    }

    #{{ section_id }} .service-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 36px 24px;
    }
  }

  @media screen and (max-width: 480px) {
    #{{ section_id }} .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "What This Service Is",
  "tag": "section",
  "class": "service-features-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What This Service Is"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading Margin Bottom",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#edeae4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 68
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding Horizontal",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (Desktop)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 54
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Font Size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a5c3a"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Description Font Size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#444444"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "building", "label": "Building / Cooking" },
            { "value": "plate", "label": "Plate / Dining" },
            { "value": "cloche", "label": "Cloche / Service" },
            { "value": "dining", "label": "Dining Table" },
            { "value": "custom", "label": "Custom Image" }
          ],
          "default": "building"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Icon Image (if Custom selected)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add a short description of this feature here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What This Service Is",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "building",
            "title": "On-Site Cooking Experience",
            "description": "Our chefs prepare and finish dishes in real time - no trays dropped off and left behind."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "plate",
            "title": "Plated or Shared Service",
            "description": "Choose elegant plated meals or beautifully presented shared dishes."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "cloche",
            "title": "Full Service Team",
            "description": "Chefs & experienced waitstaff to manage service from start to finish."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "dining",
            "title": "A True Dining Experience",
            "description": "It's more than catering, it's a private restaurant experience in your space."
          }
        }
      ]
    }
  ]
}
{% endschema %}