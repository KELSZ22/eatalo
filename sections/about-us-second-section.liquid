{% style %}
  .ciao-bella-section {
    width: 100%;
    background-color: #ffffff;
    display: flex;
  }

  .ciao-bella-content {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 40px 80px 60px;
  }

  .ciao-bella-heading {
    font-family: 'Archivo Medium', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 600;
    line-height: 120%;
    color: #1e5649;
    text-align: left;
    margin-bottom: 30px;
  }

  .ciao-bella-text {
    font-family: 'Archivo', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    color: #1e5649;
    text-align: left;
  }

  .ciao-bella-image {
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #c4d995;
  }

  .ciao-bella-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 768px) {
    .ciao-bella-section {
      flex-direction: column;
      height: auto;
    }

    .ciao-bella-content {
      width: 100%;
      padding: 40px 20px;
      order: 2;
    }

    .ciao-bella-image {
      width: 100%;
      height: 400px;
      order: 1;
    }

    .ciao-bella-heading {
      font-size: 28px;
      text-align: center;
    }

    .ciao-bella-text {
      text-align: center;
    }
  }
{% endstyle %}

<div class="ciao-bella-section">
  <div class="ciao-bella-content">
    <h2 class="ciao-bella-heading">{{ section.settings.heading }}</h2>
    <div class="ciao-bella-text">{{ section.settings.description }}</div>
  </div>

  <div class="ciao-bella-image">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
    {% else %}
      <div style="color: #1e5649; font-family: 'Archivo', sans-serif; font-size: 80px; font-weight: 600; text-align: center;">
        Ciao<br>
        <span style="color: #ffffff;">Bella</span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Ciao Bella Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Concept: Coffee & Food, Italian classic with a twist."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>At EATALO, we bring the warmth of an Italian kitchen straight to the heart of Sydney. Think freshly made dishes with a contemporary twist, crafted with the same care and passion that Nonna would put into every meal. It's food that feels familiar yet exciting, wholesome, authentic, and full of flavour. More than just a place to eat, EATALO is a space to gather, share, and savour simple moments made special. Your daily dose of joy.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Ciao Bella Section"
    }
  ]
}
{% endschema %}
