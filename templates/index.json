    "faq_section_Bd7c4Y": {
      "type": "faq-section",
      "blocks": {
        "faq_item_anUczR": {
          "type": "faq_item",
          "settings": {
            "question": "How far in advance do I need to place an order?",
            "answer": "<p>We recommend placing orders at least 24 hours in advance.For large or customised orders, 48 hours’ notice is preferred.For events catering for 200+ people, we recommend 3–5 days’ notice to ensure availability and the best service.</p>"
          }
        },
        "faq_item_PN496m": {
          "type": "faq_item",
          "settings": {
            "question": "Do you cater for corporate events and recurring orders?",
            "answer": "<p>Yes. We specialise in:</p><ul><li>Office catering</li><li>Meetings and workshops</li><li>Recurring weekly orders</li></ul><p>For ongoing catering, please contact us to discuss tailored solutions.</p>"
          }
        },
        "faq_item_iW3hYF": {
          "type": "faq_item",
          "settings": {
            "question": "Is there a minimum order amount?",
            "answer": "<p>No, there is <strong>no minimum order requirement</strong>.</p>"
          }
        },
        "faq_item_GmB3eA": {
          "type": "faq_item",
          "settings": {
            "question": "What payment methods do you accept?",
            "answer": "<p>We accept all major payment methods through our secure checkout, including Visa, MasterCard and American Express.</p><p>If you have an account with us, you may also choose to:</p><ul><li>Pay via online invoice, or</li><li>Have orders billed to your account (payment due within 7 business days)</li></ul><p>All payments are processed securely.</p>"
          }
        },
        "faq_item_qTkXXy": {
          "type": "faq_item",
          "settings": {
            "question": "Do you cater for dietary requirements?",
            "answer": "<p>Yes. We offer a wide range of options, including:</p><ul><li>Vegetarian</li><li>Vegan</li><li>Gluten-free</li><li>Dairy-free</li><li>Nut-free</li><li>Halal</li></ul><p>Please note that while we take great care, our kitchen is not a fully allergen-free environment.</p>"
          }
        },
        "faq_item_gXQBR3": {
          "type": "faq_item",
          "settings": {
            "question": "Can you cater for last-minute orders?",
            "answer": "<p>Sometimes — depending on availability.<br/>Please contact us directly and we’ll let you know as soon as possible.</p>"
          }
        },
        "faq_item_6U4QeU": {
          "type": "faq_item",
          "settings": {
            "question": "Can I customise my catering order?",
            "answer": "<p>Absolutely. You can:</p><ul><li>Mix and match menu items</li><li>Adjust quantities</li><li>Request substitutions (subject to availability)</li></ul><p>For fully customised menus, please contact us directly.</p>"
          }
        },
        "faq_item_i4JxcF": {
          "type": "faq_item",
          "settings": {
            "question": "How many people does one platter serve?",
            "answer": "<p>Recommended serving sizes are listed with each menu item.<br/>If you’re unsure, our team is happy to help you choose the right quantities.</p>"
          }
        },
        "faq_item_GqDCMj": {
          "type": "faq_item",
          "settings": {
            "question": "Do you deliver, or can I pick up?",
            "answer": "<p>We offer <strong>both delivery and pickup</strong>.<br/>Available delivery windows and pickup times can be selected during checkout.</p>"
          }
        },
        "faq_item_aLVJdR": {
          "type": "faq_item",
          "settings": {
            "question": "Can I speak to someone before placing a large order?",
            "answer": "<p>Of course. For large or event orders, we recommend contacting us so we can assist you personally.</p>"
          }
        },
        "faq_item_H9r66Y": {
          "type": "faq_item",
          "settings": {
            "question": "What areas do you deliver to?",
            "answer": "<p>We currently deliver throughout the Sydney CBD and surrounding suburbs.<br/>If your location falls outside our standard delivery area, please get in touch and we’ll do our best to accommodate.</p>"
          }
        },
        "faq_item_4FCrXt": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer eco-friendly packaging?",
            "answer": "<p>Yes. We aim to use recyclable and sustainable packaging wherever possible.</p>"
          }
        },
        "faq_item_rhUQtw": {
          "type": "faq_item",
          "settings": {
            "question": "How is the food packaged?",
            "answer": "<p>All catering is packed in professional, food-safe packaging, clearly labelled and designed for easy sharing in office and event settings.</p>"
          }
        },
        "faq_item_Ut4EXp": {
          "type": "faq_item",
          "settings": {
            "question": "What happens if my delivery is late?",
            "answer": "<p>We work to strict delivery schedules.<br/> If an issue arises, our team will contact you immediately to keep you informed.</p>"
          }
        },
        "faq_item_L4brNL": {
          "type": "faq_item",
          "settings": {
            "question": "Can I cancel or change my order?",
            "answer": "<p>Yes — changes or cancellations are possible with sufficient notice:</p><ul><li><strong>Standard orders:</strong> Up to 24 hours’ notice</li><li><strong>Large orders:</strong> Minimum 48 hours’ notice</li><li><strong>Large group orders (100–200 people):</strong> At least 5 business days’ notice</li></ul><p>Requests outside these timeframes may not be possible due to preparation and sourcing requirements.</p>"
          }
        },
        "faq_item_NGNdRG": {
          "type": "faq_item",
          "settings": {
            "question": "Do you provide invoices for corporate clients?",
            "answer": "<p>Yes. Invoices and receipts are available upon request.</p>"
          }
        },
        "faq_item_mPjHhm": {
          "type": "faq_item",
          "settings": {
            "question": "Do you provide invoices for corporate clients?",
            "answer": "<p>Yes. Invoices and receipts are available upon request.</p>"
          }
        },
        "faq_item_PiGprF": {
          "type": "faq_item",
          "settings": {
            "question": "Can I order catering for early mornings?",
            "answer": "<p>Yes. Early morning delivery slots are available, subject to availability.</p>"
          }
        },
        "faq_item_rEVp3i": {
          "type": "faq_item",
          "settings": {
            "question": "Do you cater for private events as well?",
            "answer": "<p>Yes, we cater for private parties, birthdays and celebrations.</p>"
          }
        }
      },
