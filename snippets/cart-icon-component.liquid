{%- doc -%}
  Renders the cart icon, which displays the number of items in the cart via a bubble.
{%- enddoc -%}
<cart-icon
  class="
    header-actions__cart-icon
    {% unless cart == empty %} header-actions__cart-icon--has-cart{% endunless %}
  "
  data-testid="cart-icon"
>
  <span
    class="svg-wrapper"
    aria-hidden="true"
  >
    {{ 'EATALO_Cart.svg' | inline_asset_content }}
  </span>
  <span class="cart-icon__text">Cart</span>

  {% render 'cart-bubble', limit: 100, live_region: true, test_id: test_id %}
</cart-icon>

{% stylesheet %}
  cart-icon {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }

  .cart-icon__text {
    font-family: var(--header-text-font-family, var(--font-paragraph--family));
    font-size: var(--header-text-font-size, var(--font-size--sm));
    font-weight: 600;
    color: currentColor;
  }

  @media screen and (max-width: 749px) {
    .cart-icon__text {
      display: none;
    }
  }

  cart-icon:has(.cart-bubble__text-count:empty) {
    --cart-bubble-size: 10px;
    --cart-bubble-top: 9px;
    --cart-bubble-right: 9px;

    .svg-wrapper {
      --cart-bubble-top: 4px;
      --cart-bubble-right: 4px;
    }
  }

  .header-actions__cart-icon .cart-bubble {
    left: 0px;
  }
{% endstylesheet %}
