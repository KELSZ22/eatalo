    }
  }

  .quote-modal__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
    transition: opacity 0.3s ease;
  }

  .quote-modal__backdrop[hidden] {
    display: none;
  }

  .quote-modal .quote-modal__content[open] {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1000;
    margin: 0;
    animation: quoteModalFadeIn 0.3s ease forwards;
  }

  .quote-modal .quote-modal__content.dialog-closing {
    animation: quoteModalFadeOut 0.3s ease forwards;
  }

  @keyframes quoteModalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes quoteModalFadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @media screen and (max-width: 749px) {
    .quote-modal .quote-modal__content[open] {
      top: 0;
      left: 0;
      transform: none;
    }
  }

  .quote-modal__recaptcha-notice {
    font-size: 11px;
    color: #999;
    text-align: center;
    margin-top: 12px;
    line-height: 1.4;
  }

  .quote-modal__recaptcha-notice a {
    color: #1E5649;
    text-decoration: underline;
  }

  .quote-modal__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }
