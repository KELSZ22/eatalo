<script>
  document.addEventListener('DOMContentLoaded', function() {
    var quoteModal = document.getElementById('quote-modal');
    if (!quoteModal) return;
    var dialog = quoteModal.querySelector('dialog');
    var backdrop = quoteModal.querySelector('.quote-modal__backdrop');
    if (!dialog) return;

    dialog.showModal = function() {
      HTMLDialogElement.prototype.show.call(this);
      if (backdrop) backdrop.hidden = false;
    };

    var observer = new MutationObserver(function() {
      if (dialog.classList.contains('dialog-closing') && backdrop) {
        backdrop.style.opacity = '0';
      }
    });
    observer.observe(dialog, { attributes: true, attributeFilter: ['class'] });

    dialog.addEventListener('close', function() {
      if (backdrop) {
        backdrop.hidden = true;
        backdrop.style.opacity = '';
      }
    });

    // After Shopify CAPTCHA + contact form POST, the page reloads with ?contact_posted=true
    if (window.location.search.indexOf('contact_posted=true') !== -1) {
      var successModal = document.getElementById('quote-success-banner');
      if (successModal) {
        successModal.hidden = false;
        setTimeout(function() { successModal.classList.add('quote-success-modal--visible'); }, 50);
      }
      if (window.history && window.history.replaceState) {
        var cleanUrl = window.location.pathname + window.location.hash;
        window.history.replaceState(null, '', cleanUrl);
      }
    }
  });
</script>

<div id="quote-success-banner" class="quote-success-modal" hidden role="status" aria-live="polite">
  <div class="quote-success-modal__backdrop" onclick="this.parentElement.hidden=true;"></div>
  <div class="quote-success-modal__content">
    <button type="button" class="quote-success-modal__close" aria-label="Close" onclick="this.closest('.quote-success-modal').hidden=true;">&times;</button>
    <h3 class="quote-success-modal__title">Quote Submitted!</h3>
    <p class="quote-success-modal__text">Thank you! Your quote request has been submitted successfully. We'll get back to you soon.</p>
  </div>
</div>

