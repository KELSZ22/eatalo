{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: #c8de84;
    display: flex;
    flex-direction: column;
    align-items: flex-start !important;
    justify-content: flex-start !important;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 20;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer__dialog {
    overflow: hidden;
    background-color: #c8de84;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
    background-color: #c8de84;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    background-color: #c8de84;
  }

  .cart-drawer__summary {
    background-color: #c8de84;
    position: sticky;
    bottom: 0;
    z-index: 1;
  }

  .cart-drawer__header-top {
    display: flex !important;
    align-items: center;
    justify-content: flex-start !important;
    width: 100%;
    margin-bottom: var(--padding-md);
    order: -1;
    position: relative;
    text-align: left !important;
  }

  .cart-drawer__header > .cart-drawer__header-top {
    align-self: flex-start !important;
    justify-self: flex-start !important;
  }

  .cart-drawer__close-button {
    display: flex !important;
    align-items: center;
    gap: var(--gap-xs);
    color: var(--color-foreground);
    padding: var(--padding-xs) 0;
    margin-left: 0 !important;
    margin-right: 0 !important;
    order: -1;
    position: relative;
    left: 0 !important;
    right: auto !important;
    float: none !important;
    border: none !important;
  }

  .cart-drawer__header .cart-drawer__close-button {
    margin-right: 0 !important;
  }

  .cart-drawer__delivery-options {
    display: flex;
    gap: var(--gap-sm);
    margin-bottom: var(--padding-md);
    width: 100%;
  }

  .cart-drawer__delivery-option {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    padding: var(--padding-md) var(--padding-lg);
    border: 2px solid #1E5649;
    border-radius: 4px;
    background-color: transparent;
    color: #1E5649;
    cursor: pointer;
    font-size: var(--font-size--md);
    font-weight: 500;
    transition: all 0.2s ease;
    height: 48px;
    min-height: 48px;
    max-height: 48px;
    justify-content: center;
    line-height: 1;
  }

  .cart-drawer__delivery-option:hover {
    opacity: 0.8;
  }

  .cart-drawer__delivery-option--active {
    background-color: #1E5649;
    color: #ffffff;
    border-color: #1E5649;
  }

  .cart-drawer__radio-icon {
    width: 20px;
    height: 20px;
    border: 2px solid #1E5649;
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
  }

  .cart-drawer__delivery-option--active .cart-drawer__radio-icon {
    border-color: #ffffff;
  }

  .cart-drawer__delivery-option--active .cart-drawer__radio-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background-color: #ffffff;
    border-radius: 50%;
  }

  .cart-drawer__datetime-selection {
    display: flex;
    gap: 0;
    margin-bottom: var(--padding-md);
    width: 100%;
    border: 2px solid #1E5649;
    border-radius: 4px;
    overflow: visible;
    background-color: #c8de84;
    transition: none;
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer__date-wrapper,
  .cart-drawer__time-wrapper {
    flex: 1;
    position: relative;
  }

  .cart-drawer__date-wrapper {
    border-right: 2px solid #1E5649;
  }

  .cart-drawer__date-wrapper .flatpickr-wrapper {
    width: 100%;
    display: block;
  }

  .cart-drawer__input-label {
    display: none;
  }

  .cart-drawer__date-select,
  .cart-drawer__time-select {
    width: 100%;
    padding: var(--padding-md) var(--padding-lg);
    border: none;
    border-radius: 0;
    background-color: transparent;
    color: #1E5649 !important;
    cursor: pointer;
    font-size: var(--font-size--md);
    font-weight: 500;
    transition: all 0.2s ease;
    height: 48px;
    min-height: 48px;
    max-height: 48px;
    appearance: auto;
    -webkit-appearance: auto;
    -moz-appearance: auto;
    box-sizing: border-box;
    line-height: 1;
  }

  .cart-drawer__date-select:focus,
  .cart-drawer__time-select:focus {
    outline: none;
    background-color: rgba(30, 86, 73, 0.05);
  }

  .cart-drawer__date-select::-webkit-datetime-edit,
  .cart-drawer__time-select::-webkit-datetime-edit {
    color: #1E5649 !important;
  }

  .cart-drawer__date-select::-webkit-datetime-edit-fields-wrapper,
  .cart-drawer__time-select::-webkit-datetime-edit-fields-wrapper {
    color: #1E5649 !important;
  }

  .cart-drawer__date-select::-webkit-datetime-edit-text,
  .cart-drawer__time-select::-webkit-datetime-edit-text {
    color: #1E5649 !important;
  }

  .cart-drawer__date-select::-webkit-datetime-edit-month-field,
  .cart-drawer__date-select::-webkit-datetime-edit-day-field,
  .cart-drawer__date-select::-webkit-datetime-edit-year-field,
  .cart-drawer__time-select::-webkit-datetime-edit-hour-field,
  .cart-drawer__time-select::-webkit-datetime-edit-minute-field {
    color: #1E5649 !important;
  }

  .cart-drawer__date-select:invalid,
  .cart-drawer__time-select:invalid {
    color: #1E5649;
  }

  .cart-drawer__date-select,
  .cart-drawer__time-select {
    --webkit-text-fill-color: #1E5649;
  }

  .cart-drawer__date-select:hover,
  .cart-drawer__time-select:hover {
    opacity: 0.8;
  }

  .cart-drawer__date-select:focus,
  .cart-drawer__time-select:focus {
    outline: none;
    background-color: rgba(30, 86, 73, 0.05);
  }

  .cart-drawer__date-select::-webkit-calendar-picker-indicator,
  .cart-drawer__time-select::-webkit-calendar-picker-indicator {
    cursor: pointer;
    filter: invert(27%) sepia(51%) saturate(2878%) hue-rotate(130deg) brightness(94%) contrast(85%);
    opacity: 1;
  }

  .cart-drawer__date-select::-moz-calendar-picker-indicator,
  .cart-drawer__time-select::-moz-calendar-picker-indicator {
    cursor: pointer;
    opacity: 1;
  }

  .cart-drawer__date-select[value]:not([value=""]),
  .cart-drawer__time-select[value]:not([value=""]) {
    color: #1E5649 !important;
  }

  .cart-drawer__date-select::-moz-calendar-picker-indicator,
  .cart-drawer__time-select::-moz-calendar-picker-indicator {
    cursor: pointer;
  }

  .cart-drawer__date-label,
  .cart-drawer__time-label {
    display: none;
  }

  .cart-drawer__eligibility-messages {
    width: 100%;
    display: grid;
    gap: 0;
    margin: 0 0 var(--padding-md);
