  .cart-drawer__eligibility-message {
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 14px;
    border-radius: 10px;
    border: 1px solid #e7e8e4;
    background: #FFFFFFC7;
