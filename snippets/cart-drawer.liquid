{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js" defer></script>

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<script>
(function () {
  const AU_TZ = "Australia/Sydney";
  const DELIVERY_CUTOFF_HOUR = 14;
  const DELIVERY_CUTOFF_MINUTE = 30;
  const TIME_OPTIONS = buildTimeOptions();

  function buildTimeOptions() {
    const times = [];
    for (let hour = 6; hour <= 17; hour++) {
      for (const minute of [0, 30]) {
        if (hour === 17 && minute === 30) {
          times.push({ value: "17:30", label: "5:30 PM - 6:00 PM" });
          continue;
        }

        const startPeriod = hour >= 12 ? "PM" : "AM";
        const startHour = hour % 12 || 12;
        const endHour24 = minute === 30 ? hour + 1 : hour;
        const endMinute = minute === 30 ? 0 : 30;
        const endPeriod = endHour24 >= 12 ? "PM" : "AM";
        const endHour = endHour24 % 12 || 12;

        const start = `${startHour}:${String(minute).padStart(2, "0")} ${startPeriod}`;
        const end = `${endHour}:${String(endMinute).padStart(2, "0")} ${endPeriod}`;

        times.push({
          value: `${String(hour).padStart(2, "0")}:${String(minute).padStart(2, "0")}`,
          label: `${start} - ${end}`
        });
      }
    }
    return times;
  }

  function buildTimeOptionsHtml() {
    let html = '<option value="">Select Time</option>';
    for (let i = 0; i < TIME_OPTIONS.length; i++) {
      html += `<option value="${TIME_OPTIONS[i].value}">${TIME_OPTIONS[i].label}</option>`;
    }
    return html;
  }

  function getAustraliaNowParts() {
    const parts = new Intl.DateTimeFormat("en-AU", {
      timeZone: AU_TZ,
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false
    }).formatToParts(new Date());

    const map = {};
    parts.forEach((p) => {
      if (p.type !== "literal") map[p.type] = p.value;
    });

    return {
      year: Number(map.year),
      month: Number(map.month),
      day: Number(map.day),
      hour: Number(map.hour),
      minute: Number(map.minute)
    };
  }

  function isAfterDeliveryCutoffAU() {
  const now = getAustraliaNowParts();
  return now.hour > 14 || (now.hour === 14 && now.minute >= 30);
}

  function formatDateISO(year, month, day) {
    return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
  }

  function getTodayAustraliaISO() {
    const now = getAustraliaNowParts();
    return formatDateISO(now.year, now.month, now.day);
  }

  function parseISO(iso) {
    if (!iso || !/^\d{4}-\d{2}-\d{2}$/.test(iso)) return null;
    const [y, m, d] = iso.split("-").map(Number);
    return new Date(y, m - 1, d);
  }

  function toISO(dateObj) {
    return formatDateISO(dateObj.getFullYear(), dateObj.getMonth() + 1, dateObj.getDate());
  }

  function isWeekendDate(dateObj) {
    const day = dateObj.getDay();
    return day === 0 || day === 6;
  }

  function getNextBusinessDayISO(fromISO) {
    const start = parseISO(fromISO);
    if (!start) return fromISO;
    const d = new Date(start.getFullYear(), start.getMonth(), start.getDate());
    while (isWeekendDate(d)) {
      d.setDate(d.getDate() + 1);
    }
    return toISO(d);
  }

  function getNextWeekdayISO(fromDate) {
    const d = new Date(fromDate.getFullYear(), fromDate.getMonth(), fromDate.getDate());
    while (isWeekendDate(d)) {
      d.setDate(d.getDate() + 1);
    }
    return toISO(d);
  }

  function getEarliestOrderDateISO() {
    const now = getAustraliaNowParts();
    const d = new Date(now.year, now.month - 1, now.day);

    if (getActiveDeliveryType() === "delivery") {
      d.setDate(d.getDate() + 1);
      if (isAfterDeliveryCutoffAU()) {
        d.setDate(d.getDate() + 1);
      }
    }

    while (isWeekendDate(d)) {
      d.setDate(d.getDate() + 1);
    }

    return toISO(d);
  }

  function getDrawer() {
    return document.querySelector("cart-drawer-component");
  }

  function getActiveDeliveryType() {
    const active = document.querySelector(".cart-drawer__delivery-option--active");
    return active ? (active.dataset.deliveryType || "").toLowerCase() : "";
  }

  function getVisibleDatetimeRoot(drawer) {
    const roots = Array.from(drawer.querySelectorAll(".cart-drawer__datetime-selection"));
    return roots.find((el) => el.offsetParent !== null) || roots[0] || drawer;
  }

  function getVisibleMessageRoot(drawer) {
    const roots = Array.from(drawer.querySelectorAll(".cart-drawer__eligibility-messages"));
    return roots.find((el) => el.offsetParent !== null) || roots[0] || drawer;
  }

  function getDrawerInputs() {
    const drawer = getDrawer();
    if (!drawer) return { date: null, time: null, location: null };
    const root = getVisibleDatetimeRoot(drawer);
    const boundDateInput =
      root.querySelector('.cart-drawer__date-select[data-custom-calendar-ready="true"]') ||
      root.querySelector('.cart-drawer__date-select[type="date"]') ||
      root.querySelector(".cart-drawer__date-select");
    return {
      date: boundDateInput,
      time: root.querySelector(".cart-drawer__time-select"),
      location: drawer.querySelector(".cart-drawer__delivery-location-input")
    };
  }

  function getEffectiveDateValue(dateInput) {
    if (!dateInput) return "";
    if (dateInput.dataset && dateInput.dataset.isoValue) return dateInput.dataset.isoValue;
    return dateInput.value || "";
  }

  function isDateTimeSelected() {
    const { date, time } = getDrawerInputs();
    return Boolean(date && getEffectiveDateValue(date) && time && time.value);
  }

  function getCartTotal() {
    const candidates = [
      document.querySelector("[data-cart-subtotal]"),
      document.querySelector("[data-cart-total]"),
      document.querySelector(".totals__subtotal-value"),
      document.querySelector(".cart-drawer__summary [data-money]"),
      document.querySelector(".cart__subtotal"),
      document.querySelector(".totals__subtotal")
    ].filter(Boolean);

    if (!candidates.length) return 0;

    const node = candidates[0];
    const attrValue = (node.getAttribute("value") || "").trim();
    const textValue = (node.textContent || "").trim();
    const raw = attrValue || textValue;
    if (!raw) return 0;

    const cleaned = raw.replace(/[^0-9.,-]/g, "");
    const normalized = cleaned.includes(",") && !cleaned.includes(".") ? cleaned.replace(",", ".") : cleaned.replace(/,/g, "");
    let amount = parseFloat(normalized);
    if (Number.isNaN(amount)) return 0;

    if (attrValue && !normalized.includes(".") && Math.abs(amount) >= 1000) {
      amount = amount / 100;
    }

    return amount;
  }

  function setEligibilityMessageState(messageId, visible) {
    const drawer = getDrawer();
    if (!drawer) return;
    const root = getVisibleMessageRoot(drawer);
    const node = root.querySelector(`#${messageId}`);
    if (!node) return;
    node.hidden = !visible;
  }

  function updateCartNoteVisibility(deliveryType) {
    const cartNote = document.querySelector("cart-note");
    if (!cartNote) return;
    cartNote.style.display = deliveryType === "pickup" ? "none" : "flex";
  }

  function populateTimeDropdowns(force) {
    const selects = document.querySelectorAll(".cart-drawer__time-select");
    if (!selects.length) return;
    const optionsHtml = buildTimeOptionsHtml();

    selects.forEach((select) => {
      const current = select.value || "";
      const optionCount = select.querySelectorAll("option").length;
      const needsPopulate = force || optionCount <= 1 || select.dataset.timeHydrated !== "true";
      if (!needsPopulate) return;

      select.innerHTML = optionsHtml;
      select.dataset.timeHydrated = "true";

      if (current && select.querySelector(`option[value="${current}"]`)) {
        select.value = current;
      } else {
        select.value = "";
      }
    });
  }

  function startTimeSelectObserver() {
    if (window.__timeSelectObserverStarted) return;
    window.__timeSelectObserverStarted = true;

    const observer = new MutationObserver(function () {
      populateTimeDropdowns(false);
    });

    observer.observe(document.body, { childList: true, subtree: true });
  }

  function clearDateInput(dateInput) {
    if (dateInput._flatpickr) {
      dateInput._flatpickr.clear();
    }
    dateInput.value = "";
    dateInput.defaultValue = "";
    dateInput.removeAttribute("value");
    dateInput.dataset.userSelected = "false";
    dateInput.dataset.isoValue = "";
  }

  function enforceDateNotPast(dateInput) {
    const minISO = getEarliestOrderDateISO();
    dateInput.setAttribute("min", minISO);

    if (dateInput._flatpickr) {
      dateInput._flatpickr.set("minDate", minISO);
      dateInput._flatpickr.redraw();
    }

    const effective = getEffectiveDateValue(dateInput);
    if (!effective) return true;

    const parsed = parseISO(effective);
    if (!parsed) {
      clearDateInput(dateInput);
      return false;
    }

    if (effective < minISO) {
      clearDateInput(dateInput);
      return false;
    }

    if (isWeekendDate(parsed)) {
      clearDateInput(dateInput);
      return false;
    }

    if (getActiveDeliveryType() === "delivery") {
      const now = getAustraliaNowParts();
      const todayISO = formatDateISO(now.year, now.month, now.day);
      if (effective === todayISO) {
        clearDateInput(dateInput);
        return false;
      }
      if (isAfterDeliveryCutoffAU()) {
        const tmrw = new Date(now.year, now.month - 1, now.day + 1);
        const tomorrowISO = toISO(tmrw);
        if (effective === tomorrowISO) {
          clearDateInput(dateInput);
          return false;
        }
      }
    }

    dateInput.dataset.userSelected = "true";
    dateInput.dataset.isoValue = effective;
    return true;
  }

  function validateDateWeekday() {
    const { date } = getDrawerInputs();
    const effective = getEffectiveDateValue(date);
    if (!date || !effective) return false;

    const d = parseISO(effective);
    if (!d) return false;

    if (isWeekendDate(d)) {
      clearDateInput(date);
      return false;
    }
    return true;
  }

  function bindCustomDateInput(dateInput) {
    if (dateInput.dataset.customCalendarReady === "true") return;
    dateInput.dataset.customCalendarReady = "true";

    dateInput.removeAttribute("inputmode");
    dateInput.removeAttribute("autocomplete");

    if (typeof flatpickr === "undefined") {
      dateInput.type = "date";
      dateInput.readOnly = false;
      dateInput.setAttribute("min", getEarliestOrderDateISO());
      if (dateInput.dataset.userSelected !== "true") clearDateInput(dateInput);
      return;
    }

    dateInput.type = "text";
    dateInput.readOnly = true;
    dateInput.placeholder = "Select Date";

    var minISO = getEarliestOrderDateISO();
    var dialog = dateInput.closest("dialog");

    var fp = flatpickr(dateInput, {
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "D, M j, Y",
      minDate: minISO,
      disableMobile: true,
      static: true,
      disable: [
        function(date) {
          var day = date.getDay();
          if (day === 0 || day === 6) return true;
          if (getActiveDeliveryType() === "delivery") {
            var now = getAustraliaNowParts();
            var todayTs = new Date(now.year, now.month - 1, now.day).getTime();
            var checkTs = new Date(date.getFullYear(), date.getMonth(), date.getDate()).getTime();
            if (checkTs === todayTs) return true;
            if (isAfterDeliveryCutoffAU()) {
              var tomorrowTs = new Date(now.year, now.month - 1, now.day + 1).getTime();
              if (checkTs === tomorrowTs) return true;
            }
          }
          return false;
        }
      ],
      onChange: function(selectedDates, dateStr) {
        dateInput.dataset.isoValue = dateStr || "";
        dateInput.dataset.userSelected = dateStr ? "true" : "false";
        updateCheckoutButton();
      }
    });

    dateInput._flatpickr = fp;

    if (fp.altInput) {
      fp.altInput.classList.add("cart-drawer__date-select");
      fp.altInput.placeholder = "Select Date";
    }

    if (dateInput.dataset.userSelected !== "true") {
      fp.clear();
      dateInput.dataset.isoValue = "";
    }
  }

  function initDateInputs() {
    const drawer = getDrawer();
    if (!drawer) return;

    const minISO = getEarliestOrderDateISO();

    drawer.querySelectorAll(".cart-drawer__date-select").forEach((dateSelect) => {
      if (dateSelect.classList.contains("flatpickr-alt")) return;
      dateSelect.setAttribute("min", minISO);
      bindCustomDateInput(dateSelect);
      enforceDateNotPast(dateSelect);
    });
  }

  function clearInitialDateSelections() {
    const drawer = getDrawer();
    if (!drawer) return;

    drawer.querySelectorAll(".cart-drawer__date-select").forEach((dateSelect) => {
      if (dateSelect.classList.contains("flatpickr-alt")) return;
      if (dateSelect.dataset.userSelected !== "true") clearDateInput(dateSelect);
      enforceDateNotPast(dateSelect);
    });
  }

  function showByDeliveryType(type) {
    const drawer = getDrawer();
    if (!drawer) return;

    const datetimeSelection = drawer.querySelectorAll(".cart-drawer__datetime-selection");
    const deliveryFields = drawer.querySelectorAll(".cart-drawer__delivery-fields");
    const locationFields = drawer.querySelectorAll(".cart-drawer__delivery-location-field");
    const deliveryFeeRows = drawer.querySelectorAll(".cart-drawer__delivery-fee--delivery");
    const pickupRows = drawer.querySelectorAll(".cart-drawer__delivery-fee--pickup");

    const showCommon = type === "delivery" || type === "pickup";

    datetimeSelection.forEach((el) => {
      el.style.display = showCommon ? "flex" : "none";
      el.style.opacity = showCommon ? "1" : "0";
      el.style.visibility = showCommon ? "visible" : "hidden";
    });

    if (type === "delivery") {
      deliveryFields.forEach((el) => {
        el.style.display = "block";
        el.style.opacity = "1";
        el.style.visibility = "visible";
      });
      locationFields.forEach((el) => { el.style.display = "flex"; });
      deliveryFeeRows.forEach((el) => { el.style.display = "flex"; });
      pickupRows.forEach((el) => { el.style.display = "none"; });
    } else if (type === "pickup") {
      deliveryFields.forEach((el) => {
        el.style.display = "block";
        el.style.opacity = "1";
        el.style.visibility = "visible";
      });
      locationFields.forEach((el) => { el.style.display = "none"; });
      deliveryFeeRows.forEach((el) => { el.style.display = "none"; });
      pickupRows.forEach((el) => { el.style.display = "flex"; });
    } else {
      deliveryFields.forEach((el) => {
        el.style.display = "none";
        el.style.opacity = "0";
        el.style.visibility = "hidden";
      });
      locationFields.forEach((el) => { el.style.display = "none"; });
      deliveryFeeRows.forEach((el) => { el.style.display = "none"; });
      pickupRows.forEach((el) => { el.style.display = "none"; });
    }

    updateCartNoteVisibility(type);
  }

  function ensureDefaultPickup() {
    const drawer = getDrawer();
    if (!drawer) return;

    const pickup = drawer.querySelector('.cart-drawer__delivery-option[data-delivery-type="pickup"]');
    if (!pickup) return;

    drawer.querySelectorAll(".cart-drawer__delivery-option").forEach((btn) => {
      btn.classList.remove("cart-drawer__delivery-option--active");
    });

    pickup.classList.add("cart-drawer__delivery-option--active");
    showByDeliveryType("pickup");
  }

  function computeEligibility() {
    const type = getActiveDeliveryType();
    const isDelivery = type === "delivery";
    const isPickup = type === "pickup";
    const hasDateTime = isDateTimeSelected();

    const minOrderBlocked = isDelivery && getCartTotal() < 100;
    const deliveryCutoffBlocked = isDelivery && isAfterDeliveryCutoffAU();

    let valid = false;
    if (isPickup) valid = hasDateTime;
    if (isDelivery) valid = hasDateTime && !minOrderBlocked;

    return { valid, minOrderBlocked, deliveryCutoffBlocked, hasDateTime };
  }

  function setCheckoutState(enabled) {
    const checkoutButton = document.getElementById("checkout");
    if (!checkoutButton) return;

    checkoutButton.classList.toggle("cart__checkout-button--disabled", !enabled);

    if (enabled) {
      checkoutButton.removeAttribute("disabled");
      checkoutButton.setAttribute("aria-disabled", "false");
      checkoutButton.style.pointerEvents = "auto";
      checkoutButton.style.opacity = "1";
      checkoutButton.style.cursor = "pointer";
    } else {
      checkoutButton.setAttribute("disabled", "disabled");
      checkoutButton.setAttribute("aria-disabled", "true");
      checkoutButton.style.pointerEvents = "none";
      checkoutButton.style.opacity = "0.5";
      checkoutButton.style.cursor = "not-allowed";
    }
  }

  function updateCheckoutButton() {
    const checkoutButton = document.getElementById("checkout");
    if (!checkoutButton) return;

    const state = computeEligibility();
    const type = getActiveDeliveryType();

    const showMinOrder = type === "delivery" && state.minOrderBlocked;
    const showCutoff = type === "delivery" && state.deliveryCutoffBlocked && !state.hasDateTime;

    setEligibilityMessageState("cart-min-order-message", showMinOrder);
    setEligibilityMessageState("cart-cutoff-message", showCutoff);

    setCheckoutState(state.valid);

    if (typeof window.__syncCartSummaryCheckoutState === "function") {
      window.__syncCartSummaryCheckoutState();
    }
  }

  function setCartAttributes(attributes) {
    return fetch("/cart/update.js", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ attributes })
    });
  }

  function syncDeliveryPickupDetailsToCart() {
    const type = getActiveDeliveryType();
    if (!type) return Promise.resolve();

    const { date, time, location } = getDrawerInputs();
    const dateValue = date ? getEffectiveDateValue(date).trim() : "";
    const timeValue = time ? time.value.trim() : "";
    const locationValue = location ? location.value.trim() : "";

    const attrs = {
      "Delivery type": type === "pickup" ? "Pickup" : "Delivery",
      "Delivery Date": "",
      "Delivery Time": "",
      "Pickup Date": "",
      "Pickup Time": "",
      "Delivery Location": ""
    };

    if (type === "pickup") {
      attrs["Pickup Date"] = dateValue;
      attrs["Pickup Time"] = timeValue;
    } else {
      attrs["Delivery Date"] = dateValue;
      attrs["Delivery Time"] = timeValue;
      attrs["Delivery Location"] = locationValue;
    }

    return setCartAttributes(attrs);
  }

  function syncNoteToCart(noteValue) {
    return fetch("/cart/update.js", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ note: noteValue })
    });
  }

  function validateForCheckout() {
    const { date } = getDrawerInputs();
    if (date && !enforceDateNotPast(date)) return false;

    const state = computeEligibility();
    if (!state.valid) return false;
    if (!validateDateWeekday()) return false;
    return true;
  }

  function initDeliveryOptionsOnce() {
    const drawer = getDrawer();
    if (!drawer || drawer.dataset.deliveryReady === "true") return;
    drawer.dataset.deliveryReady = "true";

    drawer.addEventListener("click", function (e) {
      const option = e.target.closest(".cart-drawer__delivery-option");
      if (!option) return;

      e.preventDefault();
      e.stopPropagation();

      drawer.querySelectorAll(".cart-drawer__delivery-option").forEach((btn) => {
        btn.classList.remove("cart-drawer__delivery-option--active");
      });
      option.classList.add("cart-drawer__delivery-option--active");

      showByDeliveryType((option.dataset.deliveryType || "").toLowerCase());
      populateTimeDropdowns(true);
      initDateInputs();
      updateCheckoutButton();
    });
  }

  function initCore() {
    initDeliveryOptionsOnce();
    populateTimeDropdowns(true);
    initDateInputs();
    ensureDefaultPickup();
    clearInitialDateSelections();
    updateCheckoutButton();

    setTimeout(function () { populateTimeDropdowns(true); }, 50);
    setTimeout(function () { initDateInputs(); clearInitialDateSelections(); }, 120);
    setTimeout(function () { populateTimeDropdowns(true); }, 200);
  }

  function resetDeliveryOptions() {
    const drawer = getDrawer();
    if (!drawer) return;

    drawer.querySelectorAll(".cart-drawer__delivery-option").forEach((opt) => {
      opt.classList.remove("cart-drawer__delivery-option--active");
    });

    drawer.querySelectorAll(".cart-drawer__datetime-selection").forEach((el) => {
      el.style.display = "none";
      el.style.opacity = "0";
      el.style.visibility = "hidden";
    });

    drawer.querySelectorAll(".cart-drawer__delivery-fields").forEach((field) => {
      field.style.display = "none";
      field.style.opacity = "0";
      field.style.visibility = "hidden";
    });

    drawer.querySelectorAll(".cart-drawer__delivery-location-input").forEach((input) => {
      input.value = "";
    });

    drawer.querySelectorAll(".cart-drawer__date-select").forEach((input) => {
      if (input.classList.contains("flatpickr-alt")) return;
      clearDateInput(input);
    });

    drawer.querySelectorAll(".cart-drawer__time-select").forEach((input) => {
      input.value = "";
    });

    ensureDefaultPickup();
    populateTimeDropdowns(true);
    initDateInputs();
    updateCheckoutButton();
  }

  function saveDrawerState() {
    var drawer = getDrawer();
    if (!drawer) return null;
    var type = getActiveDeliveryType();
    if (!type) return null;
    var inputs = getDrawerInputs();
    return {
      type: type,
      dateISO: inputs.date ? (inputs.date.dataset.isoValue || "") : "",
      dateUserSelected: inputs.date ? (inputs.date.dataset.userSelected || "") : "",
      timeValue: inputs.time ? inputs.time.value : "",
      locationValue: inputs.location ? inputs.location.value : ""
    };
  }

  function restoreDrawerState(state) {
    if (!state || !state.type) return;
    var drawer = getDrawer();
    if (!drawer) return;

    drawer.querySelectorAll(".cart-drawer__delivery-option").forEach(function(btn) {
      btn.classList.remove("cart-drawer__delivery-option--active");
      if ((btn.dataset.deliveryType || "").toLowerCase() === state.type) {
        btn.classList.add("cart-drawer__delivery-option--active");
      }
    });
    showByDeliveryType(state.type);

    initDateInputs();

    if (state.dateUserSelected === "true" && state.dateISO) {
      var inputs = getDrawerInputs();
      if (inputs.date) {
        inputs.date.dataset.isoValue = state.dateISO;
        inputs.date.dataset.userSelected = "true";
        if (inputs.date._flatpickr) {
          inputs.date._flatpickr.setDate(state.dateISO, true);
        } else {
          inputs.date.value = state.dateISO;
        }
      }
    }

    populateTimeDropdowns(false);
    if (state.timeValue) {
      var tInputs = getDrawerInputs();
      if (tInputs.time) tInputs.time.value = state.timeValue;
    }

    if (state.locationValue) {
      var lInputs = getDrawerInputs();
      if (lInputs.location) lInputs.location.value = state.locationValue;
    }

    updateCheckoutButton();
  }

  window.resetDeliveryOptions = resetDeliveryOptions;
  window.updateCheckoutButton = updateCheckoutButton;

  document.addEventListener("DOMContentLoaded", function () {
    startTimeSelectObserver();
    initCore();
    updateCartNoteVisibility("pickup");
  });

  document.addEventListener("click", function (e) {
    if (e.target.closest('button[on\\:click="/open"]')) {
      setTimeout(initCore, 120);
      setTimeout(function () { populateTimeDropdowns(true); }, 250);
      setTimeout(function () { initDateInputs(); clearInitialDateSelections(); }, 300);
    }

    if (
      e.target.closest(".cart-drawer__close-button") ||
      e.target.closest('button[on\\:click="cart-drawer-component/close"]') ||
      e.target.closest(".cart__keep-shopping-button")
    ) {
      setTimeout(resetDeliveryOptions, 50);
    }
  });

  document.addEventListener("dialog-close", function (e) {
    const drawer = getDrawer();
    if (drawer && e.target && e.target === drawer.querySelector("dialog")) {
      resetDeliveryOptions();
    }
  });

  document.addEventListener("change", function (e) {
    if (!e.target) return;

    if (e.target.classList.contains("cart-drawer__date-select") && e.target.dataset.customCalendarReady === "true") {
      enforceDateNotPast(e.target);
      validateDateWeekday();
      updateCheckoutButton();
      return;
    }

    if (e.target.classList.contains("cart-drawer__time-select")) {
      updateCheckoutButton();
    }

    if (e.target.id === "cart-terms-checkbox") {
      updateCheckoutButton();
    }
  });

  document.addEventListener("input", function (e) {
    if (e.target && e.target.id === "cart-drawer-note") {
      clearTimeout(window._noteDebounce);
      const val = e.target.value;
      window._noteDebounce = setTimeout(function () {
        syncNoteToCart(val);
      }, 500);
    }
  });

  document.addEventListener("click", function (e) {
    const checkoutButton = e.target.closest('[name="checkout"], [href="/checkout"], .cart-drawer__checkout-button, .cart__checkout-button, #checkout');
    if (!checkoutButton) return;

    e.preventDefault();

    if (!validateForCheckout()) {
      updateCheckoutButton();
      return;
    }

    syncDeliveryPickupDetailsToCart().finally(function () {
      window.location.href = "/checkout";
    });
  }, true);

  document.addEventListener("cart:update", function () {
    var saved = saveDrawerState();
    setTimeout(function () { restoreDrawerState(saved); }, 150);
  });
})();
</script>

