{% liquid
  assign block_settings = block.settings
  assign heading = block_settings.heading | default: 'Quick Links'
  assign link_1_text = block_settings.link_1_text | default: 'Menus'
  assign link_1_url = block_settings.link_1_url | default: '#'
  assign link_2_text = block_settings.link_2_text | default: 'Catering'
  assign link_2_url = block_settings.link_2_url | default: '#'
  assign link_3_text = block_settings.link_3_text | default: 'About Us'
  assign link_3_url = block_settings.link_3_url | default: '#'
  assign link_4_text = block_settings.link_4_text | default: 'Contact'
  assign link_4_url = block_settings.link_4_url | default: '#'

%}

<div
  class="
    footer-custom-menu-block
    spacing-style
  "
  style="
    --link-font-size: {{ block_settings.link_font_size }}px;
    --link-font-size-mobile: {{ block_settings.link_font_size_mobile }}px;
    {% render 'spacing-style', settings: block_settings %}
  "
  {{ block.shopify_attributes }}
>
  <div class="footer-custom-menu-block__content">
    {% if heading != blank %}
      <h3 class="footer-custom-menu-block__heading">{{ heading }}</h3>
    {% endif %}
    <div class="footer-custom-menu-block__links">
      {% if link_1_text != blank %}
        <a href="{{ link_1_url }}" class="footer-custom-menu-block__link">
          {{ link_1_text }}
        </a>
      {% endif %}

      {% if link_2_text != blank %}
        <a href="{{ link_2_url }}" class="footer-custom-menu-block__link">
          {{ link_2_text }}
        </a>
      {% endif %}

      {% if link_3_text != blank %}
        <a href="{{ link_3_url }}" class="footer-custom-menu-block__link">
          {{ link_3_text }}
        </a>
      {% endif %}

      {% if link_4_text != blank %}
        <a href="{{ link_4_url }}" class="footer-custom-menu-block__link">
          {{ link_4_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .footer-custom-menu-block {
    display: flex;
    align-items: flex-start;
  }

  .footer-custom-menu-block__content {
    display: flex;
    flex-direction: column;
    gap: 25px;
    width: 100%;
  }

  .footer-custom-menu-block__heading {
    font-family: var(--font-body-family);
    font-weight: 500;
    font-size: var(--link-font-size);
    line-height: 1.2;
    color: inherit;
    margin: 0;
  }

  .footer-custom-menu-block__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-custom-menu-block__link {
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-size: 16px;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer-custom-menu-block__link:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 750px) {
    .footer-custom-menu-block__heading {
      font-size: var(--link-font-size-mobile);
    }

    .footer-custom-menu-block__link {
      font-size: var(--link-font-size-mobile);
    }
  }
  @media screen and (max-width: 425px){
    .footer-custom-menu-block__heading{
      font-weight: 900;
}
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Menu Links",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quick Links"
    },
    {
      "type": "header",
      "content": "Link 1"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Link 1 Text",
      "default": "Menus"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "header",
      "content": "Link 2"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Link 2 Text",
      "default": "Catering"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "header",
      "content": "Link 3"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Link 3 Text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "header",
      "content": "Link 4"
    },
    {
      "type": "text",
      "id": "link_4_text",
      "label": "Link 4 Text",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "range",
      "id": "link_font_size",
      "label": "Font Size (Desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "link_font_size_mobile",
      "label": "Font Size (Mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom Menu Links",
      "category": "Footer",
      "settings": {
        "heading": "Quick Links",
        "link_1_text": "Menus",
        "link_2_text": "Catering",
        "link_3_text": "About Us",
        "link_4_text": "Contact",
        "link_font_size": 16,
        "link_font_size_mobile": 14
      }
    }
  ]
}
{% endschema %}