

{%- assign block_settings = block.settings -%}

<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
  {% capture children %}
    {% comment %} Description Blocks {% endcomment %}
    {% if product.description != blank %}
      <div class="product-details-description product-details-description-1">
        <div class="text-block">
          <p>{{ product.description | strip_html | truncatewords: 50 }}</p>
        </div>
      </div>
      <div class="product-details-description product-details-description-2">
        <div class="text-block">
          <ul style="list-style: none; padding: 0; margin: 16px 0;">
            {% assign features = product.description | split: '.' %}
            {% for feature in features limit: 4 %}
              {% if feature != blank %}
                <li style="display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; color: #1E5649;">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0; margin-top: 2px;">
                    <path d="M13.3333 4L6 11.3333L2.66667 8" stroke="#1E5649" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{{ feature | strip }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}

    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  /* Product Title Styling */
  .product-details-title {
    margin-bottom: 16px;
  }

  .product-title-text {
    color: #1E5649 !important;
    font-family: 'Archivo', sans-serif;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .product-title-text {
      font-size: 24px;
    }
  }

  /* Container styles */
  .product-details {
    display: flex;
    align-self: start;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .product-details > .group-block {
      height: min-content;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }

  /* Product Details Block - Color #1E5649 for all text */
  .product-details,
  .product-details * {
    color: #1E5649;
  }

  .product-details .text-block p,
  .product-details .text-block h1,
  .product-details .text-block h2,
  .product-details .text-block h3,
  .product-details .text-block h4,
  .product-details .text-block h5,
  .product-details .text-block h6,
  .product-details product-price,
  .product-details product-price * {
    color: #1E5649 !important;
  }

  /* Exclude product-description blocks with custom colors from global color rule */
  .product-details .product-description-wrapper .text-block,
  .product-details .product-description-wrapper .text-block * {
    color: var(--product-description-color, #1E5649) !important;
  }



  /* Size Dropdown Styling */
  .product-details-size-dropdown {
    width: 100%;
    margin: 16px 0;
  }

  .product-details-size-dropdown label {
    display: block;
    color: #1E5649;
    font-family: 'Archivo', sans-serif;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .product-details-size-select {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #1E5649;
    border-radius: 8px;
    background-color: #ffffff;
    color: #1E5649;
    font-family: 'Archivo', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 6L8 10L12 6' stroke='%231E5649' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    background-size: 16px;
    padding-right: 48px;
  }

  .product-details-size-select:focus {
    outline: none;
    border-color: #1E5649;
  }

  @media screen and (max-width: 425px){
    .product-description-wrapper{
      font-size: 14px;
    }
    .spacing-style p {
      font-size: 14px;
    }
  }

{% endstylesheet %}


