      "default": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.965954444955!2d151.20891631128762!3d-33.86476827311649!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae6a1e105bbb%3A0xea40f170e7dd8e0a!2sEATALO%20cafe%20(previously%20Bertoni)!5e0!3m2!1sen!2sph!4v1760514208073!5m2!1sen!2sph"
    },
    {
      "type": "range",
      "id": "map_width",
      "label": "Map Width (Desktop)",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "map_width_mobile",
      "label": "Map Width (Mobile)",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "map_height",
      "label": "Map Height (Desktop)",
      "min": 150,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 250
    },
    {
      "type": "range",
      "id": "map_height_mobile",
      "label": "Map Height (Mobile)",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "range",
      "id": "cafe_name_size",
      "label": "Cafe Name Size (Desktop)",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
