      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "address_size_mobile",
      "label": "Address Size (Mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
