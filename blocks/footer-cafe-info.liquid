    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width (Desktop)",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo Width (Mobile)",
      "min": 50,
      "max": 250,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Cafe Information"
    },
    {
      "type": "text",
      "id": "cafe_name",
      "label": "Cafe Name"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address Line 1",
      "default": "Corner Phillip Street and 2/8-18 Bent St,"
    },
    {
      "type": "text",
      "id": "address_line_2",
