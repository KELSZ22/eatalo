{% liquid
  assign block_settings = block.settings
  assign logo_image = block_settings.logo_image
  assign logo_text = block_settings.logo_text | default: 'EATALO'
  assign cafe_name = block_settings.cafe_name | default: 'EATALO Cafe'
  assign address_line_1 = block_settings.address_line_1 | default: 'Corner Phillip Street and, 2/8-18 Bent St,'
  assign address_line_2 = block_settings.address_line_2 | default: 'Sydney NSW 2000'
%}

<div
  class="
    footer-logo-with-address-block
    spacing-style
  "
  style="
    --logo-width: 300px;
    --logo-height: 120px;
    --cafe-name-size: {{ block_settings.cafe_name_size }}px;
    --address-size: {{ block_settings.address_size }}px;
    --cafe-name-size-mobile: {{ block_settings.cafe_name_size_mobile }}px;
    --address-size-mobile: {{ block_settings.address_size_mobile }}px;
    --gap-between: {{ block_settings.gap_between }}px;
    --text-vertical-offset: {{ block_settings.text_vertical_offset }}px;
    {% render 'spacing-style', settings: block_settings %}
  "
  {{ block.shopify_attributes }}
>
  <div class="footer-logo-with-address-block__logo">
    {% if logo_image %}
      <div class="footer-logo-with-address-block__image-wrapper">
        {{-
          logo_image
          | image_url: width: 600
          | image_tag:
            width: 300,
            height: 120,
            class: 'footer-logo-with-address-block__image',
            alt: logo_text,
            sizes: '300px'
        -}}
      </div>
    {% else %}
      <div class="footer-logo-with-address-block__text-placeholder">
        {{ logo_text }}
      </div>
    {% endif %}
  </div>

  <div class="footer-logo-with-address-block__address">
    <div class="footer-logo-with-address-block__cafe-name">
      {{ cafe_name }}
    </div>
    <div class="footer-logo-with-address-block__address-lines">
      <div class="footer-logo-with-address-block__address-line">{{ address_line_1 }}</div>
      <div class="footer-logo-with-address-block__address-line">{{ address_line_2 }}</div>
    </div>
  </div>
</div>

{% stylesheet %}
  .footer-logo-with-address-block {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-between);
    flex-wrap: wrap;
  }

  .footer-logo-with-address-block__logo {
    flex-shrink: 0;
    width: var(--logo-width);
    height: var(--logo-height);
  }

  .footer-logo-with-address-block__image-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-logo-with-address-block__image {
    object-fit: contain;
    width: 100%;
    height: 100%;
  }

  .footer-logo-with-address-block__text-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: 48px;
    line-height: 1.1;
    color: inherit;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    background-color: rgba(255, 255, 255, 0.1);
    border: 2px dashed rgba(255, 255, 255, 0.3);
    border-radius: 8px;
  }

  .footer-logo-with-address-block__address {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
    min-width: 0;
    padding-top: calc(8px + var(--text-vertical-offset));
  }

  .footer-logo-with-address-block__cafe-name {
    font-family: var(--font-body-family);
    font-weight: 500;
    font-size: var(--cafe-name-size);
    line-height: 1.2;
    color: inherit;
    margin: 0;
  }

  .footer-logo-with-address-block__address-lines {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: -4px;
  }

  .footer-logo-with-address-block__address-line {
    font-family: var(--font-body-family);
    font-weight: 500;
    font-size: var(--address-size);
    line-height: 1.3;
    color: inherit;
    margin: 0;
  }

  .footer-logo-with-address-block__address-line:not(:first-child) {
    margin-top: -2px;
  }

  @media screen and (max-width: 750px) {
    .footer-logo-with-address-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .footer-logo-with-address-block__logo {
      width: 240px;
      height: 96px;
    }

    .footer-logo-with-address-block__text-placeholder {
      font-size: 36px;
    }

    .footer-logo-with-address-block__cafe-name {
      font-size: var(--cafe-name-size-mobile);
    }

    .footer-logo-with-address-block__address-line {
      font-size: var(--address-size-mobile);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Logo + Address",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image",
      "info": "Upload a logo image. If no image is provided, a text placeholder will be shown."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (Placeholder)",
      "default": "EATALO",
      "info": "Text shown in placeholder when no image is uploaded"
    },
    {
      "type": "text",
      "id": "cafe_name",
      "label": "Cafe Name",
      "default": "EATALO Cafe"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address Line 1",
      "default": "Corner Phillip Street and, 2/8-18 Bent St,"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address Line 2",
      "default": "Sydney NSW 2000"
    },
    {
      "type": "header",
      "content": "Text Size"
    },
    {
      "type": "range",
      "id": "cafe_name_size",
      "label": "Cafe Name Size (Desktop)",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "address_size",
      "label": "Address Size (Desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "cafe_name_size_mobile",
      "label": "Cafe Name Size (Mobile)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "address_size_mobile",
      "label": "Address Size (Mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap_between",
      "label": "Gap Between Logo and Address",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "text_vertical_offset",
      "label": "Text Vertical Position",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Move text up (negative) or down (positive) relative to logo"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Logo + Address",
      "category": "Footer",
      "settings": {
        "logo_text": "EATALO",
        "cafe_name": "EATALO Cafe",
        "address_line_1": "Corner Phillip Street and, 2/8-18 Bent St,",
        "address_line_2": "Sydney NSW 2000",
        "cafe_name_size": 18,
        "address_size": 14,
        "cafe_name_size_mobile": 16,
        "address_size_mobile": 12,
        "gap_between": 12
      }
    }
  ]
}
{% endschema %}
